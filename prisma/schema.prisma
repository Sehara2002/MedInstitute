generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String
  phone       String
  course      String
  courseId    String?   // NEW — matches Course.id from your courses.ts, used for reliable lookups
  amount      Float
  status      String    @default("pending") // pending | paid | failed
  orderId     String?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  userId      String?   // NEW — links to the logged-in student who registered, if any
  user        User?     @relation(fields: [userId], references: [id])
}

// ---- NextAuth required models ----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // only set for email+password signups; null for Google-only accounts

  accounts      Account[]
  sessions      Session[]
  registrations Registration[]
  videoViews    VideoView[]

  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Free video tracking ----

model VideoView {
  id        String   @id @default(cuid())
  userId    String
  courseId  String   // matches Course.id from courses.ts
  videoId   String   // matches the video's id in courses.ts
  viewedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, videoId])
}